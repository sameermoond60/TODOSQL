<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>To Do App</title>
    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500&display=swap"
        rel="stylesheet">
    <style>
        *,
        *::before,
        *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg: #0d0d0d;
            --surface: #161616;
            --surface2: #1e1e1e;
            --border: #2a2a2a;
            --accent: #c8f04a;
            --accent-dim: rgba(200, 240, 74, 0.12);
            --text: #f0f0f0;
            --text-muted: #666;
            --danger: #ff4a4a;
            --danger-dim: rgba(255, 74, 74, 0.1);
        }

        body {
            background: var(--bg);
            font-family: 'DM Sans', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            overflow-x: hidden;
        }

        /* Ambient glow background */
        body::before {
            content: '';
            position: fixed;
            top: -30%;
            left: 50%;
            transform: translateX(-50%);
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(200, 240, 74, 0.06) 0%, transparent 70%);
            pointer-events: none;
            z-index: 0;
        }

        .container {
            position: relative;
            z-index: 1;
            width: 100%;
            max-width: 520px;
            animation: fadeUp 0.6s ease both;
        }

        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(24px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Header */
        h1#heading {
            font-family: 'Playfair Display', serif;
            font-size: clamp(2.4rem, 8vw, 3.4rem);
            font-weight: 900;
            color: var(--text);
            letter-spacing: -0.03em;
            line-height: 1;
            margin-bottom: 0.2rem;
        }

        h1#heading span {
            color: var(--accent);
        }

        .subtitle {
            font-size: 0.82rem;
            color: var(--text-muted);
            letter-spacing: 0.15em;
            text-transform: uppercase;
            margin-bottom: 2.4rem;
            font-weight: 300;
        }

        /* Input row */
        .input-row {
            display: flex;
            gap: 0.6rem;
            margin-bottom: 2rem;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 6px 6px 6px 18px;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .input-row:focus-within {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(200, 240, 74, 0.08);
        }

        input {
            flex: 1;
            background: transparent;
            border: none;
            outline: none;
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            font-size: 0.95rem;
            font-weight: 400;
            caret-color: var(--accent);
        }

        input::placeholder {
            color: var(--text-muted);
        }

        #addtask {
            background: var(--accent);
            color: #0d0d0d;
            border: none;
            border-radius: 10px;
            padding: 0.7rem 1.4rem;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.85rem;
            font-weight: 500;
            cursor: pointer;
            letter-spacing: 0.02em;
            transition: background 0.15s, transform 0.1s, box-shadow 0.15s;
            white-space: nowrap;
            flex-shrink: 0;
        }

        #addtask:hover {
            background: #d8ff55;
            box-shadow: 0 4px 20px rgba(200, 240, 74, 0.3);
        }

        #addtask:active {
            transform: scale(0.97);
        }

        /* Task counter */
        .task-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.8rem;
            padding: 0 2px;
        }

        .task-count {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            color: var(--text-muted);
            font-weight: 500;
        }

        /* List */
        ul {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        ul li.text {
            display: flex;
            align-items: center;
            gap: 1rem;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 1rem 1.1rem;
            color: var(--text);
            font-size: 0.93rem;
            font-weight: 400;
            line-height: 1.4;
            transition: background 0.15s, border-color 0.15s, transform 0.15s;
            animation: slideIn 0.25s ease both;
            position: relative;
            overflow: hidden;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateX(-12px);
            }

            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        ul li.text::before {
            content: '';
            flex-shrink: 0;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--accent);
            opacity: 0.7;
        }

        ul li.text:hover {
            background: var(--surface2);
            border-color: #333;
            transform: translateX(3px);
        }

        ul li.text span.task-text {
            flex: 1;
        }

        /* Delete button */
        button.del {
            background: transparent;
            border: 1px solid transparent;
            border-radius: 8px;
            width: 30px;
            height: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: var(--text-muted);
            font-size: 1rem;
            line-height: 1;
            transition: background 0.15s, border-color 0.15s, color 0.15s, transform 0.1s;
            flex-shrink: 0;
        }

        button.del::before {
            content: '✕';
            font-size: 0.7rem;
            font-weight: 600;
        }

        button.del:hover {
            background: var(--danger-dim);
            border-color: var(--danger);
            color: var(--danger);
            transform: scale(1.1);
        }

        button.del:active {
            transform: scale(0.95);
        }

        /* Empty state */
        .empty-state {
            text-align: center;
            padding: 2.5rem 1rem;
            color: var(--text-muted);
            font-size: 0.85rem;
            border: 1px dashed var(--border);
            border-radius: 14px;
            display: none;
        }

        .empty-state .empty-icon {
            font-size: 2rem;
            margin-bottom: 0.6rem;
            opacity: 0.4;
            display: block;
        }

        ul:empty+.empty-state {
            display: block;
        }
    </style>
</head>

<body>
    <div class="container">
        <h1 id="heading">To<span>Do</span></h1>
        <p class="subtitle">Stay focused. Get it done.</p>

        <form action="/tasks" method="post" class="input-row">
            <input name="task" placeholder="What needs to be done?">
            <button type="submit" id="addtask">+ Add task</button>
        </form>

        <ul>
            <% tasks.forEach(task=> { %>
                <li class="text">
                    <span class="task-text">
                        <%= task.task %>
                    </span>
                    <form action="/tasks/<%=task.id%>?_method=DELETE" method="post">
                        <button type="submit" class="del"></button>
                    </form>
                </li>
                <% }) %>
        </ul>

        <div class="empty-state">
            <span class="empty-icon">📋</span>
            No tasks yet — add one above!
        </div>
    </div>
</body>



</html>