<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>DOIT — Under Development</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;1,9..40,500&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --bg: #0a0a0f;
      --card: rgba(255,255,255,0.04);
      --card-border: rgba(255,255,255,0.1);
      --accent: #c8ff57;
      --accent2: #ff57a8;
      --text: #f4f4f4;
      --muted: rgba(244,244,244,0.55);
    }

    html, body {
      width: 100%;
      height: 100%;
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      overflow: hidden;
    }

    .mesh {
      position: fixed;
      inset: 0;
      z-index: 0;
      background:
        radial-gradient(ellipse 60% 50% at 15% 20%, rgba(200,255,87,0.08) 0%, transparent 70%),
        radial-gradient(ellipse 50% 60% at 85% 80%, rgba(255,87,168,0.08) 0%, transparent 70%),
        radial-gradient(ellipse 40% 40% at 50% 50%, rgba(87,168,255,0.04) 0%, transparent 70%);
      animation: meshFloat 12s ease-in-out infinite alternate;
    }

    @keyframes meshFloat {
      from { opacity: 0.8; transform: scale(1); }
      to   { opacity: 1; transform: scale(1.04); }
    }

    .emoji-ball {
      position: fixed;
      font-size: 2rem;
      user-select: none;
      pointer-events: none;
      opacity: 0.16;
      z-index: 1;
      will-change: transform;
    }

    .center {
      position: relative;
      z-index: 5;
      width: 100vw;
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }

    .card {
      position: relative;
      width: min(520px, 94vw);
      padding: 50px 42px;
      background: var(--card);
      border: 1px solid var(--card-border);
      border-radius: 30px;
      backdrop-filter: blur(30px) saturate(1.4);
      -webkit-backdrop-filter: blur(30px) saturate(1.4);
      box-shadow:
        0 0 0 1px rgba(255,255,255,0.05),
        0 30px 80px rgba(0,0,0,0.55),
        0 0 120px rgba(200,255,87,0.05) inset;
      text-align: center;
      animation: cardIn 0.9s cubic-bezier(0.22,1,0.36,1) both;
    }

    .card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 12%;
      right: 12%;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--accent), var(--accent2), transparent);
      opacity: 0.8;
    }

    @keyframes cardIn {
      from { opacity: 0; transform: translateY(36px) scale(0.96); }
      to   { opacity: 1; transform: translateY(0) scale(1); }
    }

    .brand {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      margin-bottom: 26px;
      animation: fadeUp .7s .15s cubic-bezier(0.22,1,0.36,1) both;
    }

    .brand-icon {
      width: 42px;
      height: 42px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, var(--accent), #82e000);
      color: #111;
      font-size: 1.1rem;
      font-weight: 800;
      box-shadow: 0 4px 20px rgba(200,255,87,0.35);
    }

    .brand-name {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 1.6rem;
      letter-spacing: -0.03em;
      background: linear-gradient(135deg, #fff 35%, var(--accent));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .status-badge {
      display: inline-block;
      padding: 8px 14px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,0.08);
      background: rgba(255,255,255,0.04);
      color: var(--accent);
      font-size: 0.76rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 20px;
      animation: fadeUp .7s .25s cubic-bezier(0.22,1,0.36,1) both;
    }

    h1 {
      font-family: 'Syne', sans-serif;
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 800;
      line-height: 1.05;
      letter-spacing: -0.04em;
      margin-bottom: 16px;
      animation: fadeUp .7s .32s cubic-bezier(0.22,1,0.36,1) both;
    }

    h1 span {
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .subtitle {
      max-width: 420px;
      margin: 0 auto 28px;
      color: var(--muted);
      font-size: 0.98rem;
      line-height: 1.7;
      font-weight: 300;
      animation: fadeUp .7s .4s cubic-bezier(0.22,1,0.36,1) both;
    }

    .notice {
      margin: 0 auto 28px;
      padding: 18px 18px;
      border-radius: 18px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      text-align: left;
      animation: fadeUp .7s .48s cubic-bezier(0.22,1,0.36,1) both;
    }

    .notice-title {
      font-size: 0.86rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--accent);
      margin-bottom: 10px;
      font-weight: 500;
    }

    .notice p {
      color: var(--text);
      opacity: 0.9;
      font-size: 0.96rem;
      line-height: 1.6;
    }

    .notice p strong {
      color: #fff;
    }

    .actions {
      display: flex;
      gap: 12px;
      justify-content: center;
      flex-wrap: wrap;
      animation: fadeUp .7s .56s cubic-bezier(0.22,1,0.36,1) both;
    }

    .btn {
      min-width: 170px;
      padding: 14px 18px;
      border-radius: 12px;
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 700;
      letter-spacing: 0.03em;
      transition: transform .2s, box-shadow .2s, border-color .2s, background .2s;
    }

    .btn-primary {
      background: linear-gradient(135deg, var(--accent) 0%, #82e000 100%);
      color: #0a0a0f;
      box-shadow: 0 4px 24px rgba(200,255,87,0.28);
      font-family: 'Syne', sans-serif;
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 36px rgba(200,255,87,0.4);
    }

    .btn-secondary {
      background: rgba(255,255,255,0.04);
      color: var(--text);
      border: 1px solid rgba(255,255,255,0.1);
    }

    .btn-secondary:hover {
      transform: translateY(-2px);
      background: rgba(255,255,255,0.07);
      border-color: rgba(255,255,255,0.2);
    }

    .footer-note {
      margin-top: 22px;
      font-size: 0.84rem;
      color: var(--muted);
      animation: fadeUp .7s .65s cubic-bezier(0.22,1,0.36,1) both;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(18px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body>
  <div class="mesh"></div>

  <div class="center">
    <div class="card">
      <div class="brand">
        <div class="brand-icon">!</div>
        <div class="brand-name">DOIT</div>
      </div>

      <div class="status-badge">Page Status</div>

      <h1>Still <span>in progress.</span></h1>

      <p class="subtitle">
        This section is currently under development and is not ready to use yet.
      </p>

      <div class="notice">
        <div class="notice-title">Developer Update</div>
        <p>
          <strong>The developer has not completed the work yet.</strong><br>
          Some features, routes, or backend functionality are still being built.
          Please check back later once development is finished.
        </p>
      </div>

      <div class="actions">
        <a href="/" class="btn btn-primary">Go Back Home</a>
        <a href="/contact" class="btn btn-secondary">Contact Developer</a>
      </div>

      <p class="footer-note">Thanks for your patience ⚡</p>
    </div>
  </div>

  <script>
    const emojis = ['🚧','⚙️','🛠️','⏳','📌','✨','💻','🚀','🔧','🧠','📋','⚡'];
    const balls = [];
    const count = 24;

    for (let i = 0; i < count; i++) {
      const el = document.createElement('div');
      el.className = 'emoji-ball';
      el.textContent = emojis[Math.floor(Math.random() * emojis.length)];
      el.style.fontSize = (1.3 + Math.random() * 2) + 'rem';
      document.body.appendChild(el);

      balls.push({
        el,
        x: Math.random() * window.innerWidth,
        y: Math.random() * window.innerHeight,
        vx: (Math.random() - 0.5) * 1.4,
        vy: (Math.random() - 0.5) * 1.4,
        rot: Math.random() * 360,
        rotV: (Math.random() - 0.5) * 1.2
      });
    }

    function animate() {
      const W = window.innerWidth;
      const H = window.innerHeight;

      balls.forEach(b => {
        b.x += b.vx;
        b.y += b.vy;
        b.rot += b.rotV;

        if (b.x < -50) b.x = W + 40;
        if (b.x > W + 50) b.x = -40;
        if (b.y < -50) b.y = H + 40;
        if (b.y > H + 50) b.y = -40;

        b.el.style.transform = `translate(${b.x}px, ${b.y}px) rotate(${b.rot}deg)`;
      });

      requestAnimationFrame(animate);
    }

    animate();
  </script>
</body>
</html>